// 📈 [Phase 3] 포켓몬 성장 시스템 (경험치 & 레벨업 & 자동진화)
// =================================================================
// 1. 포켓몬 레벨업에 필요한 경험치량 계산 (공식: 레벨^3)
function getPokemonNextExp(lv) {
  // 1렙->2렙: 100, 10렙->11렙: 1000... 점점 어려워짐
  // (밸런스는 필요시 여기서 조정)
  var base = 100;
  if (lv > 50) 
    base = 250;
  return Math.floor(Math.pow(lv, 3) / 4) + base;
}
// [개편] 레벨업/경험치 획득 시 호출되는 함수 (변함없는돌 방어 로직 추가)
function gainPokemonExp(u, p, expGain) {
  if (p.lv >= MAX_POKE_LV) return "";
  
  p.exp += expGain;
  var totalMsg = "";
  var levelUpCount = 0;

  // 1. 레벨업 계산 로직
  while (true) {
    var need = getPokemonNextExp(p.lv);
    if (p.exp >= need) {
      p.exp -= need;
      p.lv++;
      levelUpCount++;
      if (p.lv >= MAX_POKE_LV) { p.exp = 0; break; }
    } else { break; }
  }

  // 2. 레벨업 성공 시 처리
  if (levelUpCount > 0) {
    totalMsg += "🆙 " + getDisplayName(p) + " (Lv." + (p.lv - levelUpCount) + " ➔ Lv." + p.lv + ") 상승!";
    
    // [핵심] 변함없는돌 체크: 장착 중이면 여기서 함수를 종료하여 진화를 막음
    if (p.equip === "변함없는돌") {
      return totalMsg; 
    }

    // ★ 여기서만 진화 체크를 합니다!
    var evoResult = checkLevelEvolution(u, p); 
    if (evoResult) {
      totalMsg += "\n✨ 오?! 포켓몬의 상태가...! " + evoResult + " 진화 성공!";
      dexCaught(u, p.pid, p.grade, p.shiny);
    }
  }
  return totalMsg;
}


