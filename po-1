// [수정됨] 전투력 랭킹 (조회 시 데이터 보정 포함)
function buildBattlePowerRanking(d, topN, sender) {
  topN = topN || 7;
  var rows = [];
  var names = Object.keys(d.users || {});
  // 랭킹 산정 중 데이터 변경이 일어날 수 있음 (미접속자 등급 부여 등)
  var dataChanged = false;
  for (var i = 0; i < names.length; i++) {
    var name = names[i];
    if (!name) 
      continue;
    var user = d.users[name];
    if (!user) 
      continue;
    normalizeUserData(user);
    if (!user.pokemons || user.pokemons.length === 0) 
      continue;
    if (ensurePokemonGrades(user)) {
      dataChanged = true;
    }
    var top = getUserTopPokemonPower(user);    // 이제 등급이 반영된 전투력이 나옴
    rows.push({
  name: name, 
  power: top.power, 
  uid: top.uid, 
  pName: top.name, 
  enh: top.enh});
  }
  // 랭킹 집계 중 데이터가 변했으면 저장 (미접속자 데이터 갱신)
  if (dataChanged) {
    saveData(d);
  }
  rows.sort(function(a, b) {
  if (b.power !== a.power) 
    return b.power - a.power;
  if ((b.enh || 0) !== (a.enh || 0)) 
    return (b.enh || 0) - (a.enh || 0);
  return (a.uid || 0) - (b.uid || 0);
});
  var myIdx = -1;
  if (sender) {
    for (var k = 0; k < rows.length; k++) {
      if (rows[k].name === sender) {
        myIdx = k;
        break;
      }
    }
  }
  return {
  rows: rows, 
  myIdx: myIdx, 
  topN: topN};
}
