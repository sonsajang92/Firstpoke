// 2. 레이드 종료 및 보상 정산 (상세 리포트: 총 체력 & 개별 딜량 표시)
function endRaidBoss(d, isClear) {
  if (!d.worldBoss || !d.worldBoss.active) 
    return "진행 중인 레이드가 없습니다.";
  var boss = d.worldBoss;
  if (!boss.logs) 
    boss.logs = {};
  var rankMsg = "";
  // --- 1. 랭킹 및 통계 산정 (성공/실패 공통) ---
  var list = [];
  var totalDamage = 0;
  for (var name in boss.logs) {
    var dmg = boss.logs[name];
    list.push({ name: name, dmg: dmg });
    totalDamage += dmg;
  }
  // 딜량 내림차순 정렬
  list.sort(function(a, b) {
    return b.dmg - a.dmg;
  });
  // --- 2. 금고(Pool) 계산 ---
  var totalPool = boss.rewardPool || 0;  // 현재 모인 돈
  
  // 🌟 [수정 포인트 1] 토벌 성공 보너스 대폭 상향 (1,000 -> 10,000)
  if (isClear) {
    totalPool += 10000;
  }
  var participantCount = list.length;
  
  // 🌟 [수정 포인트 2] 기본 지급 참가상 상향 (3 -> 100)
  var basicReward = 100;
  var usedForBasic = participantCount * basicReward;
  // 성과급 재원 (금고 - 참가상)
  var performancePool = Math.max(0, totalPool - usedForBasic);
  
  // --- 3. 분배 로직 ---
  for (var i = 0; i < list.length; i++) {
    var r = list[i];
    var u = d.users[r.name];
    if (!u) continue;
    var share = (totalDamage > 0) ? (r.dmg / totalDamage) : 0;
    var bonusCoin = Math.floor(performancePool * share);
    var finalCoin = basicReward + bonusCoin;
    var lastHitMsg = "";
    
    // 🌟 [수정 포인트 3] 막타 보너스 상향 (300 -> 2,000)
    if (isClear && boss.lastHitter === r.name) {
      finalCoin += 2000;
      lastHitMsg = " (막타+2000)";
    }
    u.dakotaCoin = (u.dakotaCoin || 0) + finalCoin;
    
    // 랭킹 로그 (상위 5명)
    if (i < 5) {
      var percent = Math.floor(share * 100);
      rankMsg += (i + 1) + "위 " + r.name + " (딜량 : " + fmtNum(r.dmg) + " / " + percent + "%) ➔ +" + fmtNum(finalCoin) + "🪙" + lastHitMsg + "\n";
    }
  }
  var title = "";
  var subTitle = "";
  if (isClear) {
    title = "🎉 레이드 토벌 성공! 🎉";
    subTitle = "💰 성공 보너스 +10,000코인 포함 분배 완료!";
  } else {
    title = "💀 제한 시간 종료... 토벌 실패";
    subTitle = "⚠️ 보스는 놓쳤지만, 적립된 코인은 정산하여 지급됩니다.";
  }
  
  var resultMsg = title + "\n\n" + subTitle + "\n" + "👹 총 체력: " + fmtNum(boss.maxHp) + "\n" + "💰 총 분배 코인: " + fmtNum(totalPool) + "개\n" + "👥 참여자: " + participantCount + "명\n" + "━━━━━━━━━━━━━━\n" + "[🏅 명예의 전당 & 정산 결과]\n" + rankMsg;
  d.worldBoss = null;  // 보스 삭제
  return resultMsg;
}
// [수정됨] 레이드 전투력 계산 (엔트리 6마리 합산)
function getRaidPower(u) {
    if (!u.party || u.party.length === 0) return 0;
    
    var totalPower = 0;
    // 엔트리에 있는 모든 포켓몬의 전투력 합산
    for(var i=0; i<u.party.length; i++) {
        var p = findUserPokemonByUid(u, u.party[i]);
        if(p) totalPower += calcBattlePower(p); 
    }
    return totalPower;
}

// 레이드 공격 실행 함수
function executeRaidAttack(d, room, sender, u, replier, decoName, finisherReady) {
  var b = d.worldBoss;
  if (!b || !b.active || b.endTime <= new Date().getTime()) {
    replier.reply("늦었습니다... 이미 레이드가 종료되었습니다.");
    return;
  }
  
  if (!b.attackCounts) b.attackCounts = {};
  if (!b.attackCounts[sender]) b.attackCounts[sender] = 0;
  b.attackCounts[sender]++;

  var power = getRaidPower(u);
  var randomRate = 0.9 + (Math.random() * 0.2);
  var raidBuffMult = 60;
  var dmg = Math.floor(power * randomRate * raidBuffMult);

  var leaderUid = (u.champTeam && u.champTeam[0]) || (u.party && u.party[0]);
  var leaderP = findUserPokemonByUid(u, leaderUid);
  
  var equipType = "", equipVal = 0;
  if (leaderP && leaderP.equip && EQUIP_DB[leaderP.equip]) {
    equipType = EQUIP_DB[leaderP.equip].type;
    equipVal = EQUIP_DB[leaderP.equip].val;
  }

  var critChance = 0.15;
  var critMult = 3.0;
  var itemMsg = "";

  if (equipType === "raid_crit_rate") {
    critChance += equipVal;
    itemMsg = " (👓두둥등장!)";
  } 
  else if (equipType === "raid_crit_dmg") {
    critMult = equipVal; 
    itemMsg = " (🌶️해리의 매운맛!)"; // 특수문자 깨짐 방지
  }

  var isCrit = Math.random() < critChance;
  var hitIcon = "💥";
  var hitTag = "공격";

  if (isCrit) {
    dmg = Math.floor(dmg * critMult);
    hitIcon = "☄️";
    hitTag = "치명타" + itemMsg;
  }

  if (finisherReady) {
    dmg = Math.floor(dmg * RAID_FINISHER_MULT);
    hitIcon = "🌌";
    hitTag = "필살기 발현" + (isCrit ? " + 치명타" : "");
  }

  b.curHp -= dmg;
  if (!b.logs[sender]) b.logs[sender] = 0;
  b.logs[sender] += dmg;

  // 🌟 [수정 완료된 부분] 적립률 대폭 상향: 25,000 데미지당 1코인 적립 (기본 5코인 보장, 최대 5000코인 제한)
  var dropCoin = 5 + Math.floor(dmg / 25000); 
  dropCoin = Math.min(5000, dropCoin); 
  if (finisherReady) dropCoin *= 2;
  b.rewardPool = (b.rewardPool || 0) + dropCoin;

  if (b.curHp <= 0) {
    b.curHp = 0;
    b.lastHitter = sender;
    var clearMsg = endRaidBoss(d, true);
    commitSave(true);
    checkAndNotifyTitles(u, replier);
    replier.reply("⚔️ [레이드] " + decoName + "님의 결정타!\n" + hitIcon + " " + hitTag + ": -" + fmtNum(dmg) + " 피해!\n💰 금고 적립: +" + dropCoin + "코인\n\n" + clearMsg);
    return;
  }

  // ★ [핵심 수정] 부상 발생 시 시간을 기록하여 공격을 막습니다.
  var isInjured = Math.random() < 0.05;
  var injureMsg = "\n💨 가볍게 반격을 피했습니다!";
  if (isInjured) {
    u.lastRaidAt = new Date().getTime(); // 부상 시간 기록
    injureMsg = "\n🚑 [부상] 보스의 반격에 당했습니다! (2분간 치료 필요)";
  }
  
  commitSave(true);
  replier.reply("⚔️ [레이드] " + decoName + "님의 총공격!\n━━━━━━━━━━━━━━\n" + hitIcon + " " + hitTag + ": " + b.name + "에게 -" + fmtNum(dmg) + " 피해!\n💰 금고 적립: +" + dropCoin + "코인" + injureMsg);
}
