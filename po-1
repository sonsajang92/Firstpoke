// [수정됨] 배틀 참가 가능 포켓몬 (오직 엔트리 멤버만!)
function getBattleEligiblePokemons(u) {
  if (!u || !u.party || u.party.length === 0) return [];
  
  var out = [];
  for (var i = 0; i < u.party.length; i++) {
    var uid = u.party[i];
    var pp = findUserPokemonByUid(u, uid);
    
