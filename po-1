    var enhBonusGold = (myP.enh || 0) * randInt(800, 4000); 
    goldGain = baseWinGold + enhBonusGold;
    // 트레이너 경험치도 65 -> 500~1000 수준으로 상향
    expGain = (u.trainerLv * 10) + randInt(300, 600); 
    coinGain = randInt(3, 12);

    // 2) 연승 기록 및 보너스
    if (affectRecord) {
      u.stats.battleWin++;
