// [수정됨] 도감 랭킹 빌더 (1순위: 마릿수, 2순위: S급 개수)
function buildDexRankingWithMyRank(d, limit, myName) {
  limit = limit || 10;
  var list = [];
  var total = getTotalDexCount();
  for (var name in d.users) {
    if (!d.users.hasOwnProperty(name)) 
      continue;
    var u = d.users[name];
    if (!u || !u.dex) 
      continue;
    var count = 0;
    var sCount = 0;    // S등급 개수
    for (var k in u.dex) {
      if (u.dex[k].caught > 0) {
        count++;
        // 잡은 것 중 최고 등급이 S라면 카운트
        if (u.dex[k].maxGrade === "S") {
          sCount++;
        }
      }
    }
    if (count <= 0) 
      continue;
    list.push({
  name: name, 
  count: count, 
  sCount: sCount, 
  percent: getDexPercent(u)});
  }
  // 정렬 로직: 마릿수 내림차순 -> S급 개수 내림차순 -> 이름 오름차순
  list.sort(function(a, b) {
  if (b.count !== a.count) 
    return b.count - a.count;
  if (b.sCount !== a.sCount) 
    return b.sCount - a.sCount;
  return String(a.name).localeCompare(String(b.name));
});
  var myIdx = -1;
  for (var i = 0; i < list.length; i++) {
    if (list[i].name === myName) {
      myIdx = i;
      break;
    }
  }
  return {
  rows: list, 
  myIdx: myIdx, 
  total: total, 
  top: list.slice(0, Math.min(limit, list.length))};
}
