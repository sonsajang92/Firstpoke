// [밸런스 패치] 60강 체제 확률표
// 0~20: 진화 지원 (혜자)
// 30~40: 통곡의 벽 (두쫀쿠 유도 시작)
// 40~60: 1~2% (두쫀쿠 필수 구간)
function enhanceRatesByRarity(nextEnh, trainerLv, rarity) {
  nextEnh = parseInt(nextEnh, 10);
  if (isNaN(nextEnh)) 
    nextEnh = 1;
  var curEnh = nextEnh - 1;
  var min = 0.01, max = 0.01;
  // [구간별 확률 설정]
  if (curEnh < 5) {
    min = 0.95;
    max = 1.00;
  } else if (curEnh < 10) {
    min = 0.80;
    max = 0.90;
  } else if (curEnh < 15) {
    min = 0.60;
    max = 0.75;
  } else if (curEnh < 20) {
    min = 0.40;
    max = 0.55;
  } else if (curEnh < 30) {
    min = 0.15;
    max = 0.30;
  } else if (curEnh < 40) {
    min = 0.03;
    max = 0.08;
  } else {
    min = 0.01;
    max = 0.02;
  }
  // 구간 내 미세 조정
  var rangeSize = 5;
  if (curEnh >= 20) 
    rangeSize = 10;
  if (curEnh >= 40) 
    rangeSize = 20;
  var segmentPos = curEnh % rangeSize;
  var t = clamp01(segmentPos / rangeSize);
  var base = max - (max - min) * t;
  // [레벨 보정] (최대 +8%)
  // 40강 이후엔 레벨빨도 거의 안 받게 너프 (쿠키 가치 보존)
  var lv = trainerLv || 1;
  var bonus = (lv - 1) * 0.0008;
  if (curEnh >= 40) 
    bonus = 0;  // 40강부터는 레벨 보정 없음 (순수 운 or 쿠키)
  else if (bonus > 0.08) 
    bonus = 0.08;
  var success = base + bonus;
  // [희귀도 보정] 전설(5성)은 30강 이후 아주 조금 보정
  if (rarity === 5 && curEnh >= 30) 
    success += 0.005;
  success = clamp01(success);
  if (success < 0.01) 
    success = 0.01;  // 최소 1% 보장
  return {
  success: success, 
  keep: 1 - success, 
  death: 0};
}
