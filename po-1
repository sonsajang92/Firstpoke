        addExpWithLevelUpMsg(u, bonusUserExp);
        
        extraLines += "🔥 " + streakLevel + "연승 보너스!!\n";
        extraLines += "💰 +" + fmtNum(bonusGold) + "💰 / ✨ 트레이너 EXP +" + bonusUserExp + "\n";
