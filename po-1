// [수정됨] 미접속자 정리 함수 (누락된 부분 복구 완료)
function manageInactiveUsers(d) {
  var now = new Date().getTime();
  var archivePath = "/sdcard/mbot_pokemon_archive.json";
  // 파일 존재 여부 확인
  var file = new java.io.File(archivePath);
  var archive = {};
  if (file.exists()) {
    var archiveStr = readFile(archivePath);    // File.read 대신 readFile 사용 권장
    if (!archiveStr) {
      // readFile이 실패했을 경우를 대비해 기존 File.read 시도 (환경 호환성)
      try {
        archiveStr = File.read(archivePath);
      }      catch (e) {
}
    }
    if (archiveStr) {
      try {
        archive = JSON.parse(archiveStr);
      }      catch (e) {
  archive = {};
}
    }
  }
  var deletedCount = 0;
  var archivedCount = 0;
  var users = d.users;
  var keys = Object.keys(users);
  var day = 24 * 60 * 60 * 1000;
  var limitDelete = 30 * day;
  var limitArchive = 2 * day;
  for (var i = 0; i < keys.length; i++) {
    var key = keys[i];
    var u = users[key];
    if (!u.lastDate) 
      continue;
    var diff = now - u.lastDate;
    if (diff > limitDelete) {
      delete users[key];
      deletedCount++;
    } else if (diff > limitArchive) {
      archive[key] = u;
      delete users[key];
      archivedCount++;
    }
  }
  // 정리 결과 저장 및 반환
  if (deletedCount > 0 || archivedCount > 0) {
    saveData(d);
    // 아카이브 파일 저장
    var fos = new java.io.FileOutputStream(file);
    var str = new java.lang.String(JSON.stringify(archive));
    fos.write(str.getBytes());
    fos.close();
    return "✅ 데이터 정리 완료!\n🗑️ 영구 삭제: " + deletedCount + "명\n📦 아카이빙: " + archivedCount + "명";
  } else {
    return "✨ 정리할 데이터가 없습니다.";
  }
}
