    // 탐험 중이면 제외
    if (isPokemonBusy(u, pp.uid)) continue; 
    
    // 최소 강화 조건 등은 유지
    if ((pp.enh || 0) >= BATTLE_MIN_ENH) out.push(pp);
  }
  return out;
}

