function getRarityBattleModifier(db, turn, hpRate) {
  var r = db.rarity || 1;
  var atkMod = 1.0;
  var defMod = 1.0;
  // 1. [2~3티어] 언더독의 반란 (버터플, 피죤투, 라이츄 등)
  // "무시하지 마라! 쥐도 궁지에 몰리면 고양이를 문다."
  // 전략: 맞으면서 버티다가, 체력 절반 이하(위기)일 때 폭딜을 넣어야 함.
  if (r <= 3) {
    if (hpRate <= 0.5) {
      atkMod = 1.25;      // 공격력 25% 떡상 (배수의 진)
    }
  } else if (r === 4) {
    if (turn >= 4 && turn <= 8) {
      atkMod = 1.15;      // 공 15% 증가
      defMod = 1.10;      // 방 10% 증가
    }
  } else if (r === 5) {
    if (turn <= 3) {
      atkMod = 0.90;      // 초반 3턴: 10% 봐줌 (방심)
    } else if (turn >= 10) {
      atkMod = 1.45;      // 10턴 이후: 45% 뎀증 (재앙)
      defMod = 1.15;      // 맷집도 세짐
    }
  }
  return {
  atk: atkMod, 
  def: defMod};
}
