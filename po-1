// -------------------- 전체보기(접기) SAFE --------------------
// 카톡/메신저봇R에서 너무 긴 메시지는 전송 실패/크래시 유발 가능
function replyFold(replier, summary, full) {
  summary = String(summary || "");
  full = String(full || "");
  
  // ✅ 요약이 길어지면, 뒤쪽을 잘라서 전체보기로 보내버림
  var SUMMARY_LIMIT = 220;  // 180~260 사이로 취향 조절
  if (summary.length > SUMMARY_LIMIT) {
    var overflow = summary.substring(SUMMARY_LIMIT);
    summary = summary.substring(0, SUMMARY_LIMIT) + "\n... (전체보기)";
    // overflow를 full 앞에 붙여서 "목록"이 전체보기에 들어가게 함
    full = overflow + "\n\n" + full;
  }
  
  // ★ [핵심 수정] 눈에 안 보이는 문자가 깨지지 않도록 유니코드(\u200b)로 직접 입력!
  var foldChar = "\u200b".repeat(500);
  
  replier.reply(summary + foldChar + (full ? ("\n" + full) : " "));
}

//골드콤마
function fmtNum(n) {
  n = parseInt(n, 10);
  if (isNaN(n)) 
    n = 0;
  return String(n).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
}
 
