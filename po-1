    return 0.25;
  if (m === 0.5) 
    return 0.95;
  if (m === 1) 
    return 1.50;
  if (m === 2) 
    return TYPE_STRONG;
  return 2.40;
}
function typeMultiplierAdjusted(attackType, defendType) {
  if (!attackType || !defendType) 
    return 2;
  var row = TYPE_CHART[attackType];
  if (!row) 
    return 2;
  var raw = row[defendType];
  return remapTypeMult((raw === undefined) ? 1 : raw);
}
