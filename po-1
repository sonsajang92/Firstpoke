          var n3 = randInt(3, 9);
          qText = "🔥[필살기] " + n1 + " + " + n2 + " × " + n3;
          ans = n1 + (n2 * n3);
        } else {
          var n1 = randInt(11, 19);
          var n2 = randInt(11, 19);
          qText = "🔥[필살기] " + n1 + " × " + n2;
          ans = n1 * n2;
        }
      } else {
        var n1 = randInt(11, 99);
        var n2 = randInt(11, 99);
        if (Math.random() < 0.5) {
          qText = n1 + " + " + n2;
          ans = n1 + n2;
        } else {
          var max = Math.max(n1, n2);
          var min = Math.min(n1, n2);
          qText = max + " - " + min;
          ans = max - min;
        }
      }

      u.raidCaptcha = {
        ans: ans, 
        finisher: isFinisherQuiz, 
        expire: new Date().getTime() + 15000
      };
      commitSave(true);

      // 출력 멘트 정리
      var countMsg = "\n(누적 공격: " + myCount + "회 / 필살기까지 " + (FINISHER_REQ - (myCount % FINISHER_REQ)) + "회)";
      if (isFinisherQuiz) {
        countMsg = "\n🔥 [필살기 발동] 고난이도 문제입니다! 집중하세요!!";
      }

      // ✅ 사장님 코드의 변수명 qText와 decoName을 정확히 매칭했습니다.
      replier.reply("🔒 [" + decoName + "님의 공격 코드]\n" + qText + " = ?\n" + countMsg);
      return;
    }

  }  catch (e) {
  // <--- ★ 2. 맨 아래 닫기 직전에 이거 추가
  Log.error("🚨 에러 발생: " + e + " (Line: " + (e.lineNumber || "Unknown") + ")");
  replier.reply("시스템 오류: " + e);
}
}
